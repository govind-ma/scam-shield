<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_bottom_nav.xml  — Part F redesign
    White background, 1dp top border. Active tab uses theme accent color on icon+label.
    Inactive tabs are neutral gray. No solid colored background block.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_nav_container"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:weightSum="1">

    <!-- 1dp top divider line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E7E0"/>

    <!-- Tab row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:weightSum="4">

        <!-- Tab 1: Home -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <TextView
                android:id="@+id/tv_nav_home_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="20sp"
                android:textColor="#9E9E9E"/>
            <TextView
                android:id="@+id/tv_nav_home_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"/>
        </LinearLayout>

        <!-- Tab 2: Chat -->
        <LinearLayout
            android:id="@+id/nav_chat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <TextView
                android:id="@+id/tv_nav_chat_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬"
                android:textSize="20sp"
                android:textColor="#9E9E9E"/>
            <TextView
                android:id="@+id/tv_nav_chat_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"/>
        </LinearLayout>

        <!-- Tab 3: Learn -->
        <LinearLayout
            android:id="@+id/nav_learn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <TextView
                android:id="@+id/tv_nav_learn_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📖"
                android:textSize="20sp"
                android:textColor="#9E9E9E"/>
            <TextView
                android:id="@+id/tv_nav_learn_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Learn"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"/>
        </LinearLayout>

        <!-- Tab 4: Settings -->
        <LinearLayout
            android:id="@+id/nav_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <TextView
                android:id="@+id/tv_nav_settings_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙"
                android:textSize="20sp"
                android:textColor="#9E9E9E"/>
            <TextView
                android:id="@+id/tv_nav_settings_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
