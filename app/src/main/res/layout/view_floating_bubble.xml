<?xml version="1.0" encoding="utf-8"?>
<!--
    view_floating_bubble.xml — Cyber Help Agent FAB
    Three layers in a FrameLayout (all centred):
      1. Outer glow ring (larger, slower pulse)
      2. Inner glow ring (tighter, slightly faster phase)
      3. The solid green circle with the shield emoji
    Glow rings are animated by ValueAnimator in FloatingAssistantService.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_bubble_root"
    android:layout_width="80dp"
    android:layout_height="80dp">

    <!-- Outer glow ring — starts at scale 1.0, animates to 1.5 -->
    <View
        android:id="@+id/glow_ring_outer"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:background="@drawable/glow_ring"
        android:alpha="0.0"/>

    <!-- Inner glow ring — starts at scale 1.0, animates to 1.3 (tighter) -->
    <View
        android:id="@+id/glow_ring_inner"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:background="@drawable/glow_ring"
        android:alpha="0.0"/>

    <!-- Shield FAB button — 60dp solid circle, centred in the 80dp frame -->
    <TextView
        android:id="@+id/fab_shield_icon"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:text="🛡"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="@drawable/circle_fab_green"
        android:elevation="10dp"
        android:stateListAnimator="@null"/>

</FrameLayout>
