<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_learn.xml
    Refactored to a beautiful card-based layout for LearnAboutScamsActivity.
    Light neutral background, white rounded cards, thin borders, chevron indicators.
    Elderly-friendly: large text (>= 18sp), generous padding, high contrast.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/learn_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F8F6">

    <!-- ── Top Bar ─────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/learn_topbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#00695C"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_learn_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📖  Learn &amp; Protect"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <!-- ── ViewFlipper for browsing topics ────────────────────────────────── -->
    <ViewFlipper
        android:id="@+id/learn_view_flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ═══════════════════════════════════════════════════════════════════
             SCREEN 0 — Main Topics Menu
             ═══════════════════════════════════════════════════════════════════ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_learn_menu_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select a topic to read:"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="12dp"/>

                <!-- Topic 1 Card -->
                <LinearLayout
                    android:id="@+id/btn_topic_safe_payment"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/card_white"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛡️"
                        android:textSize="22sp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="How to make a safe payment"
                        android:textSize="19sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➔"
                        android:textSize="20sp"
                        android:textColor="#9E9E9E"/>
                </LinearLayout>

                <!-- Topic 2 Card -->
                <LinearLayout
                    android:id="@+id/btn_topic_check_before_pay"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/card_white"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤔"
                        android:textSize="22sp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Before you transfer money"
                        android:textSize="19sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➔"
                        android:textSize="20sp"
                        android:textColor="#9E9E9E"/>
                </LinearLayout>

                <!-- Topic 3 Card (Emergency - Light Red Tint) -->
                <LinearLayout
                    android:id="@+id/btn_topic_scam_recovery"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/card_light_red"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🆘"
                        android:textSize="22sp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="What to do if scammed"
                        android:textSize="19sp"
                        android:textColor="#B71C1C"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➔"
                        android:textSize="20sp"
                        android:textColor="#B71C1C"/>
                </LinearLayout>

                <!-- Topic 4 Card -->
                <LinearLayout
                    android:id="@+id/btn_topic_common_patterns"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/card_white"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="24dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍"
                        android:textSize="22sp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Common scam patterns"
                        android:textSize="19sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➔"
                        android:textSize="20sp"
                        android:textColor="#9E9E9E"/>
                </LinearLayout>

                <!-- QUIZ ACTION BANNER -->
                <LinearLayout
                    android:id="@+id/quiz_banner_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_white"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tv_quiz_card_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✍️  Test your knowledge!"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_quiz_card_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Take our quick quiz to see if you can spot common scam messages."
                        android:textSize="17sp"
                        android:textColor="#555555"
                        android:layout_marginBottom="16dp"/>

                    <Button
                        android:id="@+id/btn_take_quiz"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Start Quiz"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#00796B"/>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- ═══════════════════════════════════════════════════════════════════
             SCREEN 1 — How to make a safe payment (checklist steps)
             ═══════════════════════════════════════════════════════════════════ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/learn_card_safe_payment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_white"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🛡️ How to make a safe payment"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#00695C"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Follow these plain-language steps whenever sending money online:"
                        android:textSize="18sp"
                        android:textColor="#555555"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. Always double-check the receiver's name\nBefore hitting pay, read the official name shown by your UPI app. Confirm it matches who you want to pay.\n\n2. Never enter your UPI PIN to RECEIVE money\nEntering your PIN only withdraws money from your account. You do NOT need to enter your PIN to receive money.\n\n3. Do not trust Caller ID names completely\nScammers can fake official names like 'Bank Support' or 'Electricity Dept' on Caller ID apps. Verify with trusted numbers.\n\n4. Never click payment links from unknown SMS\nLinks in SMS claiming 'refunds', 'cashback', or 'bill unpaid' are designed to steal your bank details.\n\n5. Call the official bank customer care number\nIf you get an alert about your account being blocked, call the official number on your physical card, not a number sent in SMS."
                        android:textSize="18sp"
                        android:textColor="#1A1A1A"
                        android:lineSpacingExtra="6dp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_back_from_safe_payment"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="← Back to topics"
                    android:textSize="18sp"
                    android:textColor="#555555"
                    android:backgroundTint="#EEEEEE"
                    android:layout_marginBottom="16dp"/>

            </LinearLayout>
        </ScrollView>

        <!-- ═══════════════════════════════════════════════════════════════════
             SCREEN 2 — What to keep in mind before paying (tick-style checklist)
             ═══════════════════════════════════════════════════════════════════ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/learn_card_check_before_pay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_white"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🤔 What to keep in mind"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#00695C"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Before you transfer any money or scan a QR code, ask yourself:"
                        android:textSize="18sp"
                        android:textColor="#555555"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="☑  Are they rushing you?\nScammers create false urgency (e.g., 'Pay in 5 minutes or get blocked'). Take a deep breath and pause.\n\n☑  Did they ask for your OTP or UPI PIN?\nNO legitimate customer care, bank executive, or police officer will ever ask for your OTP or PIN.\n\n☑  Is the deal too good to be true?\nLottery winnings, free cash gifts, or highly discounted items are standard tricks to get your attention.\n\n☑  Are they asking you to download a screen-sharing app?\nApps like AnyDesk or TeamViewer let scammers see your PINs and password as you type them. Never install these for strangers.\n\n☑  Have you spoken to a trusted family member first?\nIf you feel confused, stop and call a child, sibling, or trusted friend before hitting pay."
                        android:textSize="18sp"
                        android:textColor="#1A1A1A"
                        android:lineSpacingExtra="6dp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_back_from_check_before_pay"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="← Back to topics"
                    android:textSize="18sp"
                    android:textColor="#555555"
                    android:backgroundTint="#EEEEEE"
                    android:layout_marginBottom="16dp"/>

            </LinearLayout>
        </ScrollView>

        <!-- ═══════════════════════════════════════════════════════════════════
             SCREEN 3 — Common scam patterns (Cards explaining flags)
             ═══════════════════════════════════════════════════════════════════ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔍 Common scam patterns"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#00695C"
                    android:layout_marginBottom="16dp"/>

                <!-- Card 1: Fake Bank SMS -->
                <LinearLayout
                    android:id="@+id/learn_card_pattern1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_white"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💬 Fake Bank SMS"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="A message claiming your account or credit card is blocked. It provides a link or phone number.\nRed Flags: Asks you to call a mobile number or click a link that does not end in '.com' or '.in' representing your bank."
                        android:textSize="17sp"
                        android:textColor="#333333"/>
                </LinearLayout>

                <!-- Card 2: Lottery / Prize scams -->
                <LinearLayout
                    android:id="@+id/learn_card_pattern2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_white"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🎉 Lottery / Prize Scam"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="You won Rs 25 Lakhs or a car in a lucky draw you never entered.\nRed Flags: They ask you to pay a 'processing fee' or 'tax' first before sending you the money. You never have to pay money to get lottery winnings."
                        android:textSize="17sp"
                        android:textColor="#333333"/>
                </LinearLayout>

                <!-- Card 3: Fake relative emergency -->
                <LinearLayout
                    android:id="@+id/learn_card_pattern3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_white"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🆘 Relative in Emergency"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="A caller pretending to be police claiming your grandchild has been arrested, or a relative in a hospital needing immediate payment.\nRed Flags: They ask for transfer via UPI immediately and ask you not to tell anyone. Call the relative directly on their known number to verify."
                        android:textSize="17sp"
                        android:textColor="#333333"/>
                </LinearLayout>

                <!-- Card 4: Fake Payment request -->
                <LinearLayout
                    android:id="@+id/learn_card_pattern4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_white"
                    android:padding="16dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💸 Fake Payment Request"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Someone sends you a payment request on UPI or scans a QR code claiming they are sending you money.\nRed Flags: The app asks you to enter your UPI PIN. entering your PIN always takes money OUT of your bank account."
                        android:textSize="17sp"
                        android:textColor="#333333"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_back_from_common_patterns"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="← Back to topics"
                    android:textSize="18sp"
                    android:textColor="#555555"
                    android:backgroundTint="#EEEEEE"
                    android:layout_marginBottom="16dp"/>

            </LinearLayout>
        </ScrollView>

    </ViewFlipper>

    <!-- ── Bottom Navigation Bar ───────────────────────────────────────────── -->
    <include
        android:id="@+id/bottom_navigation_bar"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"/>

</LinearLayout>
