<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_white"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="10dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Top row: sender name + verdict pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <!-- Contact name or phone number -->
        <TextView
            android:id="@+id/tv_sms_sender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Unknown Sender"/>

        <!-- Verdict pill (SCAM / SUSPICIOUS / SAFE) -->
        <TextView
            android:id="@+id/tv_sms_verdict"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/safe_green"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/pill_verdict"
            android:text="âœ“ SAFE"/>

    </LinearLayout>

    <!-- Middle row: message preview + timestamp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:layout_marginBottom="6dp">

        <!-- Message body preview â€” capped at 2 lines with ellipsis -->
        <TextView
            android:id="@+id/tv_sms_preview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="#555555"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3"
            android:text="Message preview goes here..."/>

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tv_sms_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:text="10:30 AM"/>

    </LinearLayout>

    <!-- Bottom row: Trust button â€” hidden when trusted, visible otherwise -->
    <LinearLayout
        android:id="@+id/ll_trust_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/btn_trust_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="âœ“ Trust this message"
            android:textSize="13sp"
            android:textColor="@color/safe_green"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/pill_verdict"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</LinearLayout>

