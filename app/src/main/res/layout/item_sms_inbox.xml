<?xml version="1.0" encoding="utf-8"?>
<!--
    item_sms_inbox.xml
    Row layout for SmsInboxAdapter — one SMS message in the home page inbox view.

    Structured like a standard messaging app inbox row:
      • Top row: sender (bold left) + verdict pill (coloured right)
      • Bottom row: message preview (2-line ellipsis left) + timestamp (grey right)

    Verdict pill background colour is set programmatically in SmsInboxAdapter.
    Rounded corners for pill are handled by android:background="@drawable/pill_bg"
    which is a simple shape drawable — or by padding+background colour in code.

    Elderly-friendly: minimum 16sp text, generous padding, clear contrast.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_white"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Top row: sender + verdict pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <!-- Sender name / phone number -->
        <TextView
            android:id="@+id/tv_sms_sender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Unknown Sender"/>

        <!-- Verdict pill (SCAM / SUSPICIOUS / SAFE) — background colour set in code -->
        <TextView
            android:id="@+id/tv_sms_verdict"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#00695C"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/pill_verdict"
            android:text="✓ SAFE"/>

    </LinearLayout>

    <!-- Bottom row: message preview + timestamp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top">

        <!-- Message body preview — capped at 2 lines with ellipsis -->
        <TextView
            android:id="@+id/tv_sms_preview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="#555555"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3"
            android:text="Message preview goes here..."/>

        <!-- Timestamp — right-aligned, grey, compact -->
        <TextView
            android:id="@+id/tv_sms_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:text="10:30 AM"/>

    </LinearLayout>

</LinearLayout>
