<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settings_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ── Top Bar ─────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/settings_topbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/safe_green"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&#9881;  Settings"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/bg_primary"/>

    </LinearLayout>

    <!-- ── Bottom Navigation Bar ───────────────────────────────────────────── -->
    <include
        android:id="@+id/bottom_navigation_bar"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"/>

    <!-- ── Main Scroll Content ─────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/settings_topbar"
        android:layout_above="@id/bottom_navigation_bar"
        android:fillViewport="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="88dp">

            <!-- ════════════════════════════════════════════════════════════
                 SECTION: Protection Settings
                 ════════════════════════════════════════════════════════════ -->
            <TextView
                android:id="@+id/tv_settings_group_protection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PROTECTION SETTINGS"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:textColor="@color/text_secondary"
                android:paddingTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- Notification Access Row -->
            <LinearLayout
                android:id="@+id/btn_permission_notifications"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_settings_row"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128276;"
                    android:textSize="20sp"
                    android:textColor="@color/safe_green"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_btn_permission_notifications_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notification Protection"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grant access to scan notifications"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_btn_permission_notifications_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#8250;"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- System App Settings Row -->
            <LinearLayout
                android:id="@+id/btn_system_settings"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_settings_row"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#9881;"
                    android:textSize="20sp"
                    android:textColor="@color/safe_green"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_btn_system_settings_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System Permissions"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage SMS &amp; overlay permissions"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_btn_system_settings_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#8250;"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- Family Alert Contact Row -->
            <LinearLayout
                android:id="@+id/btn_family_contact"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_settings_row"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128106;"
                    android:textSize="20sp"
                    android:textColor="@color/safe_green"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Family Alert Contact"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tv_family_contact_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not set"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#8250;"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- Test Family Alert Row -->
            <LinearLayout
                android:id="@+id/btn_test_family_alert"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_settings_row"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128241;"
                    android:textSize="20sp"
                    android:textColor="@color/safe_green"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Test Family Alert"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Send a test SMS to your contact"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#8250;"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- ════════════════════════════════════════════════════════════
                 SECTION: Preferences
                 ════════════════════════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PREFERENCES"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:textColor="@color/text_secondary"
                android:paddingTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- Language Row -->
            <LinearLayout
                android:id="@+id/btn_language"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_settings_row"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#127760;"
                    android:textSize="20sp"
                    android:textColor="@color/safe_green"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Language"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tv_language_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="English"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#8250;"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- ════════════════════════════════════════════════════════════
                 SECTION: Storage & Data
                 ════════════════════════════════════════════════════════════ -->
            <TextView
                android:id="@+id/tv_settings_group_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STORAGE &amp; DATA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:textColor="@color/text_secondary"
                android:paddingTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- Clear Detection History Row (destructive) -->
            <LinearLayout
                android:id="@+id/btn_clear_history"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_settings_row"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128465;"
                    android:textSize="20sp"
                    android:textColor="@color/scam_red"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_btn_clear_history_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear Detection History"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/scam_red"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Permanently remove all scan records"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <!-- No chevron for destructive action -->
            </LinearLayout>

            <!-- ════════════════════════════════════════════════════════════
                 SECTION: About
                 ════════════════════════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ABOUT"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:textColor="@color/text_secondary"
                android:paddingTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- App Version Row (non-clickable) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_settings_row"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128737;"
                    android:textSize="20sp"
                    android:textColor="@color/safe_green"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scam Shield"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Version 1.0.0"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

            </LinearLayout>

            <!-- How Scam Shield Works Row -->
            <LinearLayout
                android:id="@+id/btn_how_it_works"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_settings_row"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128269;"
                    android:textSize="20sp"
                    android:textColor="@color/safe_green"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How Scam Shield Works"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The 4 pillars of protection"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#8250;"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- Privacy Policy Row -->
            <LinearLayout
                android:id="@+id/btn_privacy_policy"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_settings_row"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128274;"
                    android:textSize="20sp"
                    android:textColor="@color/safe_green"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Privacy Policy"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="On-device detection, no data shared"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#8250;"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
