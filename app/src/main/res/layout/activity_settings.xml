<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_settings.xml
    Refactored to card design: rounded cards, border, light-neutral background, chevrons.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settings_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- â”€â”€ Top Bar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <LinearLayout
        android:id="@+id/settings_topbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/safe_green"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="âš™  Settings &amp; Permissions"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

    </LinearLayout>

    <!-- â”€â”€ Bottom Navigation Bar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <include
        android:id="@+id/bottom_navigation_bar"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"/>

    <!-- â”€â”€ Main Scroll Content â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/settings_topbar"
        android:layout_above="@id/bottom_navigation_bar"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="88dp">

            <!-- Language Group Title -->
            <TextView
                android:id="@+id/tv_settings_group_language"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Language"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp"/>

            <!-- Language Selector Card -->
            <LinearLayout
                android:id="@+id/btn_language_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="24dp"
                android:clickable="false"
                android:focusable="false">

                <TextView
                    android:id="@+id/tv_language_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="App Language"
                    android:textSize="17sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/btn_lang_english"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="English"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/card_elevated"
                        android:backgroundTint="@null"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btn_lang_hindi"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Hindi"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/card_white"
                        android:backgroundTint="@null"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btn_lang_gujarati"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Gujarati"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/card_white"
                        android:backgroundTint="@null"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Family Alert Group Title -->
            <TextView
                android:id="@+id/tv_settings_group_family"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Family Alert Contact"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp"/>

            <!-- Family Alert Contact Card -->
            <LinearLayout
                android:id="@+id/card_family_alert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tv_family_alert_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="When a scam is detected, alert this person"
                    android:textSize="17sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <android.widget.EditText
                        android:id="@+id/et_family_phone"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:hint="Family member phone number"
                        android:inputType="phone"
                        android:textSize="17sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/card_elevated"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btn_test_family_alert"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Test"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/card_elevated"
                        android:backgroundTint="@null"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Permissions Group Title -->
            <TextView
                android:id="@+id/tv_settings_group_protection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="App Protection Settings"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp"/>

            <!-- Notification Access Card Button -->
            <LinearLayout
                android:id="@+id/btn_permission_notifications"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/card_white"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ðŸ””"
                    android:textSize="22sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tv_btn_permission_notifications_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Notification Protection"
                    android:textSize="19sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_btn_permission_notifications_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="âž”"
                    android:textSize="20sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- System App Details Settings Card Button -->
            <LinearLayout
                android:id="@+id/btn_system_settings"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/card_white"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="âš™"
                    android:textSize="22sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tv_btn_system_settings_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Manage System Permissions"
                    android:textSize="19sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_btn_system_settings_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="âž”"
                    android:textSize="20sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- Data & Storage Group Title -->
            <TextView
                android:id="@+id/tv_settings_group_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Storage &amp; Data"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp"/>

            <!-- Clear History Card Button (Light Red warning tint) -->
            <LinearLayout
                android:id="@+id/btn_clear_history"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/card_light_red"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ðŸ—‘ï¸"
                    android:textSize="22sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tv_btn_clear_history_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Clear Detection History"
                    android:textSize="19sp"
                    android:textColor="@color/scam_red"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_btn_clear_history_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="âž”"
                    android:textSize="20sp"
                    android:textColor="@color/scam_red"/>
            </LinearLayout>

            <!-- About Group Title -->
            <TextView
                android:id="@+id/tv_settings_group_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="About"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"/>

            <!-- Version Card -->
            <LinearLayout
                android:id="@+id/card_about_version"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/card_white"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/safe_green"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tv_about_version_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Version 1.0.0"
                    android:textSize="19sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- How it Works Card -->
            <LinearLayout
                android:id="@+id/btn_how_it_works"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/card_white"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="?"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/safe_green"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tv_how_it_works_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="How Scam Shield works"
                    android:textSize="19sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_how_it_works_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textSize="20sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- Privacy Policy Card -->
            <LinearLayout
                android:id="@+id/btn_privacy_policy"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/card_white"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/safe_green"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tv_privacy_policy_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Privacy Policy"
                    android:textSize="19sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_privacy_policy_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textSize="20sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>

