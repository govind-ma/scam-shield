<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_home.xml — SAFE MODE dashboard for HomeActivity.
    Light neutral base (#F7F8F6), white rounded cards with thin borders,
    coloured icon badges, and a glowing floating shield button.
    Elderly-friendly: large text, generous padding, high contrast.
    Alert-mode theming is applied at runtime in HomeActivity.applyHomeTheme().
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/home_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8F6">

    <!-- Bottom Navigation Bar -->
    <include
        android:id="@+id/bottom_navigation_bar"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"/>

    <!-- Scrollable Dashboard -->
    <ScrollView
        android:id="@+id/home_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation_bar"
        android:background="@android:color/transparent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="24dp">

            <!-- Premium Header Section with Gradient -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_header_gradient"
                android:padding="20dp">

                <!-- App Header: shield icon + title -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_gravity="start"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/iv_app_shield"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_shield_filled"
                        android:tint="#FFFFFF"
                        android:contentDescription="Scam Shield logo"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_app_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scam Shield"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:letterSpacing="-0.01"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Digital Guardian"
                            android:textSize="12sp"
                            android:textColor="#E8F5E9"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Main Content Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp">

            <!-- Protection Status Card -->
            <LinearLayout
                android:id="@+id/card_protection_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_elevated"
                android:gravity="center_vertical"
                android:padding="18dp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="24dp"
                android:elevation="4dp">

                <!-- Status content in row layout -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:id="@+id/status_icon_badge"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_badge_green"
                        android:layout_marginEnd="16dp"
                        android:elevation="2dp">

                        <ImageView
                            android:id="@+id/iv_protection_icon"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check"
                            android:tint="#FFFFFF"
                            android:contentDescription="Protection status"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_protection_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="You're protected"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"/>

                        <TextView
                            android:id="@+id/tv_protection_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="No threats found today"
                            android:textSize="13sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Card 1: Check a message or link (blue) -->
            <LinearLayout
                android:id="@+id/btn_check_something"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:background="@drawable/card_elevated"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="3dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_badge_blue"
                    android:layout_marginEnd="16dp"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/iv_btn_check_icon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_search"
                        android:tint="#FFFFFF"
                        android:contentDescription="Check icon"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_btn_check_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Check a message"
                        android:textSize="17sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Verify links and content"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_btn_check_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="32sp"
                    android:textColor="#D1D5DB"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Card 2: Learn about scams (green) -->
            <LinearLayout
                android:id="@+id/btn_learn"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:background="@drawable/card_elevated"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="3dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_badge_green"
                    android:layout_marginEnd="16dp"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/iv_btn_learn_icon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_book"
                        android:tint="#FFFFFF"
                        android:contentDescription="Learn icon"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_btn_learn_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Learn about scams"
                        android:textSize="17sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Stay informed and protected"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_btn_learn_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="32sp"
                    android:textColor="#D1D5DB"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Card 3: I got scammed - help me (urgent, light red tint) -->
            <LinearLayout
                android:id="@+id/btn_i_got_scammed"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:background="@drawable/card_light_red"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="28dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="3dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_badge_red"
                    android:layout_marginEnd="16dp"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/iv_btn_scammed_icon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_help"
                        android:tint="#FFFFFF"
                        android:contentDescription="Help icon"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_btn_scammed_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="I got scammed"
                        android:textSize="17sp"
                        android:textColor="#B71C1C"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Get emergency help now"
                        android:textSize="12sp"
                        android:textColor="#991B1B"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_btn_scammed_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="32sp"
                    android:textColor="#F87171"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

                <!-- Recent Alerts Group Title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="14dp"
                    android:layout_marginStart="0dp">

                    <TextView
                        android:id="@+id/tv_recent_alerts_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent alerts"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View all ›"
                        android:textSize="13sp"
                        android:textColor="#3B6D11"/>
                </LinearLayout>

                <!-- Empty State Card -->
                <LinearLayout
                    android:id="@+id/tv_history_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_elevated"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="24dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_check"
                        android:tint="#3B6D11"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="All clear"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="All clear! No threats detected yet."
                        android:textSize="15sp"
                        android:textColor="#374151"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- RecyclerView: recent detection alert cards -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Glowing Floating Shield Button (above the nav bar, bottom-right) -->
    <FrameLayout
        android:id="@+id/fab_shield"
        android:layout_width="92dp"
        android:layout_height="92dp"
        android:layout_above="@id/bottom_navigation_bar"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/fab_glow"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Quick scan">

        <FrameLayout
            android:id="@+id/fab_circle"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:background="@drawable/fab_circle_green"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/iv_fab_shield_icon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_shield_filled"
                android:tint="#FFFFFF"
                android:contentDescription="Shield"/>
        </FrameLayout>

    </FrameLayout>

</RelativeLayout>
