<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_home.xml
    Refactored to a beautiful card-based layout for HomeActivity.
    Light neutral background, white rounded cards, thin borders, chevron indicators.
    Elderly-friendly: large text (>= 18sp), generous padding, high contrast.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/home_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8F6">

    <!-- ── Bottom Navigation Bar ───────────────────────────────────────────── -->
    <include
        android:id="@+id/bottom_navigation_bar"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"/>

    <!-- ── Scrollable Dashboard ────────────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/home_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation_bar"
        android:background="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── App Header ──────────────────────────────────────────────────── -->
            <TextView
                android:id="@+id/tv_app_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🛡  Scam Shield"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"/>

            <!-- ── Protection Status Card ──────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/card_protection_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_white"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_protection_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️"
                    android:textSize="24sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tv_protection_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Scam Shield is protecting you"
                    android:textSize="18sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- ── Primary Card-Based Action Rows ────────────────────────────── -->

            <!-- Card 1: Check a message -->
            <LinearLayout
                android:id="@+id/btn_check_something"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/card_white"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_btn_check_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="22sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tv_btn_check_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Check a message or link"
                    android:textSize="19sp"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_btn_check_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➔"
                    android:textSize="20sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

            <!-- Card 2: Learn about scams -->
            <LinearLayout
                android:id="@+id/btn_learn"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/card_white"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_btn_learn_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖"
                    android:textSize="22sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tv_btn_learn_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Learn about scams"
                    android:textSize="19sp"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_btn_learn_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➔"
                    android:textSize="20sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

            <!-- Card 3: I got scammed (Light Red Tint layout) -->
            <LinearLayout
                android:id="@+id/btn_i_got_scammed"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/card_light_red"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_btn_scammed_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🆘"
                    android:textSize="22sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tv_btn_scammed_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="I got scammed — help me"
                    android:textSize="19sp"
                    android:textColor="#B71C1C"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_btn_scammed_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➔"
                    android:textSize="20sp"
                    android:textColor="#B71C1C"/>
            </LinearLayout>

            <!-- ── Recent Alerts Group Title ────────────────────────────────────── -->
            <TextView
                android:id="@+id/tv_recent_alerts_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recent alerts"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginBottom="8dp"/>

            <!-- Empty State Card -->
            <TextView
                android:id="@+id/tv_history_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:text="No alerts yet. Scam Shield is watching."
                android:textSize="17sp"
                android:textColor="#757575"
                android:gravity="center"
                android:padding="20dp"
                android:layout_marginBottom="16dp"/>

            <!-- RecyclerView History Alert Cards -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
