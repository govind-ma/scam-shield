<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_home.xml â€” Restructured Home dashboard for HomeActivity.

    New structure (top â†’ bottom inside the ScrollView):
      1. App header (shield + title)        â€” unchanged
      2. Protection status card             â€” unchanged
      3. â”€â”€ SMS Inbox section â”€â”€            â€” NEW: full device SMS list with scam labels
      4. â”€â”€ Quick Actions section â”€â”€        â€” MOVED: was between header and alerts
      5. â”€â”€ Recent Scam Alerts section â”€â”€   â€” MOVED: was above quick actions

    The floating shield FAB and bottom nav bar remain outside the ScrollView,
    unchanged from before. FloatingAssistantService is completely unrelated to
    this layout and is not affected.

    Alert-mode theming is applied at runtime in HomeActivity.applyHomeTheme().
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/home_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Bottom Navigation Bar â€” unchanged, still anchored to bottom -->
    <include
        android:id="@+id/bottom_navigation_bar"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"/>

    <!-- Scrollable Dashboard -->
    <ScrollView
        android:id="@+id/home_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation_bar"
        android:background="@android:color/transparent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="88dp">

            <!-- Premium Header Section with Gradient -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_header_gradient"
                android:padding="20dp">

                <!-- App Header: shield icon + title -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_gravity="start"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/iv_app_shield"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_shield_filled"
                        android:tint="@color/text_primary"
                        android:contentDescription="Scam Shield logo"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_app_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scam Shield"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:letterSpacing="-0.01"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Digital Guardian"
                            android:textSize="12sp"
                            android:textColor="#E8F5E9"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Main Content Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp">

            <!-- Guardian Status Card - Centered with stats -->
            <LinearLayout
                android:id="@+id/card_protection_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_elevated"
                android:gravity="center"
                android:padding="24dp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="28dp"
                android:elevation="4dp">

                <!-- Centered Shield Icon -->
                <FrameLayout
                    android:id="@+id/status_icon_badge"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_badge_green"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/iv_protection_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_shield_filled"
                        android:tint="@color/text_primary"
                        android:contentDescription="Guardian shield"/>
                </FrameLayout>

                <!-- Status Text -->
                <TextView
                    android:id="@+id/tv_protection_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOU'RE PROTECTED"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp"/>

                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:baselineAligned="false">

                    <!-- Scams Blocked -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">

                        <TextView
                            android:id="@+id/tv_scams_blocked_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#FF1744"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scams Blocked"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/surface_border"/>

                    <!-- Messages Scanned -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tv_messages_scanned_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/safe_green"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>


            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
                 SMS INBOX SECTION  â† NEW
                 Reads the full device SMS inbox, labels each message SAFE or SCAM.
                 â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->

            <!-- Section heading -->
            <TextView
                android:id="@+id/tv_sms_inbox_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SMS Inbox"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"/>

            <!-- Sub-label explaining the scam labels -->
            <TextView
                android:id="@+id/tv_sms_inbox_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Each message is checked for scams automatically"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp"/>

            <!-- Loading indicator â€” shown while SmsInboxLoader is running -->
            <ProgressBar
                android:id="@+id/pb_sms_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <!-- Empty state: shown when READ_SMS denied or inbox is empty -->
            <TextView
                android:id="@+id/tv_sms_inbox_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_elevated"
                android:text="No messages to show.\nScam Shield needs SMS permission to scan your inbox."
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:padding="20dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"/>

            <!-- The main inbox RecyclerView â€" filled by SmsInboxAdapter -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_sms_inbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"/>

            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
                 DIVIDER
                 Visual separator between inbox and the action buttons below.
                 â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/surface_border"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="20dp"/>

            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
                 QUICK ACTIONS SECTION  â† MOVED DOWN (was between header and alerts)
                 â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->

            <TextView
                android:id="@+id/tv_quick_actions_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp"/>

            <!-- Card 1: Check a message or link (redesigned with 88dp height & card_elevated) -->
            <LinearLayout
                android:id="@+id/btn_check_something"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:background="@drawable/card_elevated"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="3dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_badge_blue"
                    android:layout_marginEnd="16dp"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/iv_btn_check_icon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_search"
                        android:tint="@color/text_primary"
                        android:contentDescription="Check icon"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_btn_check_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Check a message"
                        android:textSize="17sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Verify links and content"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_btn_check_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â€º"
                    android:textSize="32sp"
                    android:textColor="#D1D5DB"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Card 2: Learn about scams -->
            <LinearLayout
                android:id="@+id/btn_learn"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:background="@drawable/card_elevated"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="3dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_badge_green"
                    android:layout_marginEnd="16dp"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/iv_btn_learn_icon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_book"
                        android:tint="@color/text_primary"
                        android:contentDescription="Learn icon"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_btn_learn_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Learn about scams"
                        android:textSize="17sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Stay informed and protected"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_btn_learn_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â€º"
                    android:textSize="32sp"
                    android:textColor="#D1D5DB"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Card 3: I got scammed â€” urgent, light red tint -->
            <LinearLayout
                android:id="@+id/btn_i_got_scammed"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:background="@drawable/card_light_red"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="28dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="3dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_badge_red"
                    android:layout_marginEnd="16dp"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/iv_btn_scammed_icon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_help"
                        android:tint="@color/text_primary"
                        android:contentDescription="Help icon"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_btn_scammed_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="I got scammed"
                        android:textSize="17sp"
                        android:textColor="@color/scam_red"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Get emergency help now"
                        android:textSize="12sp"
                        android:textColor="#991B1B"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_btn_scammed_chevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â€º"
                    android:textSize="32sp"
                    android:textColor="#F87171"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

                <!-- Recent Alerts Group Title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="14dp"
                    android:layout_marginStart="0dp">

                    <TextView
                        android:id="@+id/tv_recent_alerts_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent Scam Alerts"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View all â€º"
                        android:textSize="13sp"
                        android:textColor="@color/safe_green"
                        android:visibility="gone"/> <!-- Hidden unless needed -->
                </LinearLayout>

                <!-- Empty State Card -->
                <LinearLayout
                    android:id="@+id/card_history_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_elevated"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="24dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_check"
                        android:tint="@color/safe_green"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="All clear"/>

                    <TextView
                        android:id="@+id/tv_history_empty"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="All clear! No threats detected yet."
                        android:textSize="15sp"
                        android:textColor="#374151"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- RecyclerView: recent detection alert cards -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Glowing Floating Shield Button â€” unchanged, still above nav bar at bottom-right -->
    <FrameLayout
        android:id="@+id/fab_shield"
        android:layout_width="92dp"
        android:layout_height="92dp"
        android:layout_above="@id/bottom_navigation_bar"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/fab_glow"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Quick scan">

        <FrameLayout
            android:id="@+id/fab_circle"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:background="@drawable/fab_circle_green"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/iv_fab_shield_icon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_shield_filled"
                android:tint="@color/text_primary"
                android:contentDescription="Shield"/>
        </FrameLayout>

    </FrameLayout>

</RelativeLayout>

