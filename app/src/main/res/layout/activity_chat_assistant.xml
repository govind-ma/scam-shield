<!--
    activity_chat_assistant.xml ├втВмтАЭ Cyber Help Agent chat screen (Safe Mode)
    Design system: bg @color/bg_primary, card #FFFFFF, border #E5E7E0, green #3B6D11, red #E24B4A.
    Glowing shield header, rounded chat bubbles, pill input bar with
    paperclip + mic + send icons. Elderly-friendly: large text, generous padding.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ├втАЭтВм├втАЭтВм Top bar with glowing shield ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <LinearLayout
        android:id="@+id/chat_topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/safe_green"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- Glowing shield badge -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/glow_white">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_shield_filled"
                app:tint="@color/safe_green"
                android:contentDescription="Shield"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tv_chat_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cyber Help Agent"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/bg_secondary"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_badge_green"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Online ├В┬╖ Powered by Gemini AI"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ├втАЭтВм├втАЭтВм Bottom Navigation Bar ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <include
        android:id="@+id/bottom_navigation_bar"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"/>

    <!-- ├втАЭтВм├втАЭтВм Input Area (above bottom nav) ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <LinearLayout
        android:id="@+id/layout_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@color/bg_secondary"
        android:layout_above="@id/bottom_navigation_bar"
        android:elevation="8dp"
        android:gravity="center_vertical">

        <!-- Attach / image picker button -->
        <ImageView
            android:id="@+id/btn_attach"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_attach"
            android:background="@drawable/bg_icon_button"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Attach image"/>

        <!-- Text input -->
        <EditText
            android:id="@+id/et_chat_input"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Ask about a message, link, or image├втВм┬ж"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:background="@drawable/bg_input_field"
            android:inputType="textShortMessage|textMultiLine"
            android:maxLines="3"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <!-- Voice / microphone button -->
        <ImageView
            android:id="@+id/btn_mic"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_mic"
            android:background="@drawable/bg_icon_button"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:contentDescription="Voice input"/>

        <!-- Send button -->
        <ImageView
            android:id="@+id/btn_chat_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/bg_send_button"
            android:backgroundTint="@color/safe_green"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Send message"/>

    </LinearLayout>

    <!-- ├втАЭтВм├втАЭтВм Scrollable chat area ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <ScrollView
        android:id="@+id/chat_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/chat_topbar"
        android:layout_above="@id/layout_input"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Agent label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cyber Help Agent"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"/>

            <!-- Greeting bubble from agent -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_bubble_agent"
                android:padding="18dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hello! I'm your Cyber Help Agent."
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="I can help you:\n\n├втВм┬в  Check if an SMS or link is a scam\n├втВм┬в  Look at a screenshot of a suspicious message\n├втВм┬в  Answer a spoken question ├втВмтАЭ just tap the mic\n\nType, speak, or attach a screenshot below."
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="5dp"/>
            </LinearLayout>

            <!-- Dynamic conversation thread appended here by code -->
            <LinearLayout
                android:id="@+id/layout_chat_thread"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>

