<?xml version="1.0" encoding="utf-8"?>
<!--
    shield_pulse_scam.xml
    Fast, urgent pulse for the shield icon in Alert / Scam Mode (red state).
    Scale: 1.0 → 1.12 over 400ms, reverses, repeats infinitely.
    Alpha: 0.70 → 1.0 — creates a rapid warning flash.
-->
<set xmlns:android="http://schemas.android.com/apk/res/android">

    <scale
        android:fromXScale="1.0"
        android:toXScale="1.12"
        android:fromYScale="1.0"
        android:toYScale="1.12"
        android:pivotX="50%"
        android:pivotY="50%"
        android:duration="400"
        android:repeatMode="reverse"
        android:repeatCount="infinite"
        android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>

    <alpha
        android:fromAlpha="0.70"
        android:toAlpha="1.0"
        android:duration="400"
        android:repeatMode="reverse"
        android:repeatCount="infinite"
        android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>

</set>
