<?xml version="1.0" encoding="utf-8"?>
<!-- Soft concentric red glow rings behind the floating shield button (Alert Mode). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#20E24B4A" />
        </shape>
    </item>
    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp">
        <shape android:shape="oval">
            <solid android:color="#33E24B4A" />
        </shape>
    </item>
    <item
        android:left="20dp"
        android:top="20dp"
        android:right="20dp"
        android:bottom="20dp">
        <shape android:shape="oval">
            <solid android:color="#4DE24B4A" />
        </shape>
    </item>
</layer-list>
