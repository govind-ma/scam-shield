<?xml version="1.0" encoding="utf-8"?>
<!-- Soft concentric green glow rings behind the floating shield button.
     Three translucent green ovals of increasing inset create a halo. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outermost, faintest ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#143B6D11" />
        </shape>
    </item>
    <!-- Middle ring -->
    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp">
        <shape android:shape="oval">
            <solid android:color="#243B6D11" />
        </shape>
    </item>
    <!-- Inner ring, closest to the button -->
    <item
        android:left="20dp"
        android:top="20dp"
        android:right="20dp"
        android:bottom="20dp">
        <shape android:shape="oval">
            <solid android:color="#383B6D11" />
        </shape>
    </item>
</layer-list>
